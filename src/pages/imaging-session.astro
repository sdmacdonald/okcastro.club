---
// src/pages/imaging-session.astro
// Okie-Tex PixInsight Imaging Workshop registration
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---
<Layout title="PixInsight Imaging Workshop — Okie-Tex Star Party">

  <!-- ── Hero ──────────────────────────────────────────────── -->
  <Hero image="/bg.jpg" overlay={[0.55, 0.88]}>
    <img src="/otsp-logo__white.png" alt="Okie-Tex Star Party"
         class="mx-auto" style="height:220px; opacity:0.95; margin-bottom:-16px" />
    <h1 class="font-display font-bold text-ds-text leading-[1.1] tracking-tight mb-3"
        style="font-size: clamp(32px,5vw,56px)">
      PixInsight Imaging Session<br>
      <span style="font-size: clamp(20px,3vw,36px); opacity:0.75">Intermediate Course</span>
    </h1>
    <p class="font-body text-[14px] font-semibold uppercase tracking-widest text-ds-text-2">
      Presented by Jon Talbot
    </p>
  </Hero>

  <!-- ── Two-column: info + form ────────────────────────────── -->
  <section class="bg-ds-raised py-20 px-6">
    <div class="max-w-4xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Info column -->
      <div>
        <h2 class="font-display font-bold text-ds-text text-[clamp(20px,2.5vw,28px)] tracking-tight mb-4">
          About the Session
        </h2>

        <div class="space-y-5 mb-10">
          <p class="font-body text-[14px] text-ds-text-2 leading-[1.75]">
            This year's imaging session is an intermediate-level workshop designed for
            astrophotographers who are ready to move beyond the basics.
            <strong class="text-ds-text">Attendees must have PixInsight installed on their laptops before arriving.</strong>
            Once registration fills out, Jon will send detailed instructions on the datasets
            and additional resources you'll need to download in advance.
          </p>
          <p class="font-body text-[14px] text-ds-text-2 leading-[1.75]">
            The course covers two core workflows for imaging with color CMOS cameras:
          </p>
          <div>
            <p class="font-body text-[10px] font-bold uppercase tracking-[0.1em] mb-2 text-ds-sky">Part 1: RGB Color Processing</p>
            <p class="font-body text-[14px] text-ds-text-2 leading-[1.75]">
              Jon will walk through his complete workflow for processing a typical RGB color image
              from start to finish. The techniques covered apply equally to mono and color cameras,
              making this section valuable regardless of your imaging setup.
            </p>
          </div>
          <div>
            <p class="font-body text-[10px] font-bold uppercase tracking-[0.1em] mb-2 text-ds-sky">Part 2: Narrowband + RGB with Color CMOS</p>
            <p class="font-body text-[14px] text-ds-text-2 leading-[1.75]">
              This section digs into the specifics of combining RGB and narrowband data using a
              color CMOS camera and dual narrowband filters, an increasingly popular approach
              that comes with its own set of challenges. Jon will detail his full workflow using
              the latest PixInsight tools, including an overview of what's new in the software
              for handling all types of imaging data.
            </p>
          </div>
          <p class="font-body text-[13px] italic text-ds-text-2">
            Space is limited. Registration details coming soon.
          </p>
        </div>

        <hr class="border-white/[0.08] mb-6" />

        <p class="font-body text-[10px] font-bold uppercase tracking-[0.1em] mb-3 text-ds-sky">
          About the Instructor
        </p>
        <p class="font-body text-[14px] text-ds-text leading-[1.75] mb-3">
          Jon Talbot is a retired USAF "Hurricane Hunter" turned master astrophotographer.
          He employs a Software Bisque Paramount MYT, Stellarvue refractors, and a custom
          carbon-fiber Newtonian astrograph. A familiar face at Okie-Tex, and keynote
          speaker at the Texas Star Party.
        </p>
        <a href="http://starscapeimaging.com/" target="_blank" rel="noreferrer"
           class="font-body text-[13px] underline underline-offset-2 transition-colors text-ds-sky">
          starscapeimaging.com ↗
        </a>
      </div>

      <!-- Form column -->
      <div class="rounded-lg p-8 bg-ds-surface border border-white/10">
        <h2 class="font-display font-bold text-ds-text text-[clamp(20px,2.5vw,26px)] tracking-tight mb-1">
          Reserve Your Seat
        </h2>
        <p class="font-body text-[13px] text-ds-text-2 mb-7">
          $100 per person. Okie-Tex registration required.
        </p>

        <form id="imaging-form" novalidate>
          <div class="mb-4">
            <label class="form-label" for="img-name">Full Name <span class="text-ds-pink">*</span></label>
            <input id="img-name" name="name" type="text" class="form-input"
                   placeholder="Leo Spaceman" required autocomplete="name" />
          </div>
          <div class="mb-6">
            <label class="form-label" for="img-email">Email Address <span class="text-ds-pink">*</span></label>
            <input id="img-email" name="email" type="email" class="form-input"
                   placeholder="cosmo@example.com" required autocomplete="email" />
          </div>
          <button type="submit" id="img-submit"
                  class="bg-ds-otsp text-ds-text w-full py-3 text-[15px] font-semibold rounded font-body transition-colors">
            Reserve Seat — $100
          </button>
          <div id="img-error" class="hidden mt-3 p-3 rounded border border-ds-pink/40 bg-ds-pink/10 text-ds-pink text-[13px]"></div>
        </form>
      </div>

    </div>
  </section>

  <!-- ── Stripe Payment Modal ───────────────────────────────── -->
  <div id="payment-modal"
       class="fixed inset-0 z-[200] hidden items-center justify-center p-4"
       style="background: rgba(9,11,20,0.85); backdrop-filter: blur(4px);">
    <div class="bg-ds-surface border border-white/[0.09] rounded-lg shadow-[0_8px_48px_rgba(0,0,0,0.7)]
                w-full max-w-md p-8">
      <div class="flex items-start justify-between mb-6">
        <div>
          <h3 class="font-display font-bold text-ds-text text-[22px] leading-tight">Complete payment</h3>
          <p class="font-body text-[13px] text-ds-text-3 mt-1">PixInsight Workshop — $100</p>
        </div>
        <button id="modal-close" type="button" aria-label="Close"
                class="text-ds-text-3 hover:text-ds-text transition-colors mt-1">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <form id="payment-form">
        <div id="payment-element" class="mb-5"></div>
        <div id="payment-error" class="hidden mb-4 text-[13px] text-ds-pink"></div>
        <button type="submit" id="payment-submit"
                class="bg-ds-otsp text-ds-text w-full py-3 text-[15px] font-semibold rounded font-body">
          Pay $100
        </button>
      </form>
    </div>
  </div>

</Layout>

<script>
  const form = document.getElementById('imaging-form');
  const imgError = document.getElementById('img-error');
  const modal = document.getElementById('payment-modal');
  const modalClose = document.getElementById('modal-close');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = document.getElementById('img-submit');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Processing…';
    imgError.classList.add('hidden');

    const data = {
      name: form.name.value,
      email: form.email.value,
      item: 'imaging-session',
    };

    try {
      const res = await fetch('/.netlify/functions/create-checkout-session', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error((await res.json()).error || 'Payment setup failed.');
      const { clientSecret, metadata } = await res.json();

      localStorage.setItem('otsp_member', JSON.stringify({ ...data, amount: metadata.amount }));

      const stripe = Stripe(import.meta.env.PUBLIC_STRIPE_PK);
      const elements = stripe.elements({
        clientSecret,
        appearance: {
          theme: 'night',
          variables: {
            colorBackground: '#161b2e',
            colorPrimary: '#4a90c4',
            colorText: '#f0ece4',
            colorTextSecondary: '#9ea3b0',
            borderRadius: '6px',
          },
        },
      });
      const paymentEl = elements.create('payment');

      modal.classList.remove('hidden');
      modal.classList.add('flex');
      paymentEl.mount('#payment-element');

      document.getElementById('payment-form').addEventListener('submit', async (ev) => {
        ev.preventDefault();
        document.getElementById('payment-submit').disabled = true;
        document.getElementById('payment-submit').textContent = 'Processing…';
        document.getElementById('payment-error').classList.add('hidden');

        const { error } = await stripe.confirmPayment({
          elements,
          confirmParams: {
            return_url: `${window.location.origin}/success?item=imaging`,
          },
        });
        if (error) {
          const errEl = document.getElementById('payment-error');
          errEl.textContent = error.message;
          errEl.classList.remove('hidden');
          document.getElementById('payment-submit').disabled = false;
          document.getElementById('payment-submit').textContent = 'Pay $100';
        }
      }, { once: true });

    } catch (err) {
      imgError.textContent = err.message;
      imgError.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Reserve Seat — $100';
    }
  });

  modalClose?.addEventListener('click', () => {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  });
</script>
