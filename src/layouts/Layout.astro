---
import '../styles/global.css';

interface Props {
  title?: string;
  bg?: string;
}
const {
  title = "Oklahoma City Astronomy Club",
  bg = "linear-gradient(rgba(13,15,24,0.85), rgba(13,15,24,0.65)), url('/bg.jpg')",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body
    class="min-h-screen pb-8"
    style={`background-color: #0d0f18; background-image: ${bg}; background-size: cover; background-position: center; background-attachment: fixed;`}
  >
    <slot name="nav" />
    <main class="flex flex-col items-center gap-8">
      <slot />
    </main>
  </body>
</html>
