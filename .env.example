# Server-side env vars — set in the Netlify dashboard for production.
# Locally, copy this file to `.env` (gitignored) and override only the values
# you want different from production (typically just the Stripe test keys);
# `netlify dev` pulls everything else from the dashboard via `netlify link`.

# Stripe — dashboard.stripe.com → Developers → API keys.
# Use test keys locally (sk_test_*, pk_test_*); live keys live only in Netlify.
STRIPE_SK=sk_test_REPLACE_ME
PUBLIC_STRIPE_PK=pk_test_REPLACE_ME

# Stripe webhook signing secret. Locally, use the whsec_ printed by
# `stripe listen --forward-to localhost:8888/.netlify/functions/confirm-stripe-payment`.
# In production, use the secret from the Stripe webhook endpoint config.
STRIPE_ES=whsec_REPLACE_ME

# SendGrid API key — sendgrid.com → Settings → API Keys.
SENDGRID_API_KEY=SG.REPLACE_ME

# Sender / BCC / error-recipient addresses. SENDGRID_FROM_OTSP and
# SENDGRID_ERROR_RECIPIENT are optional.
SENDGRID_FROM=members@example.com
SENDGRID_FROM_OTSP=okie-tex@example.com
SENDGRID_BCC=archive@example.com
SENDGRID_ERROR_RECIPIENT=admin@example.com

# SendGrid dynamic template IDs. Format: `d-` followed by 32-char hex.
# Find them in SendGrid dashboard → Email API → Dynamic Templates.
SENDGRID_MEMBERSHIP_TEMPLATE_ID=d-REPLACE_ME
SENDGRID_IMAGING_TEMPLATE_ID=d-REPLACE_ME
